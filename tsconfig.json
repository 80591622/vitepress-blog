{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "importHelpers": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client", "vitepress/client"],
    "paths": {
      "@/*": ["./source/*"]
    }
  },
  "include": [
    "source/.vitepress/**/*.ts",
    "source/.vitepress/**/*.d.ts",
    "source/**/*.ts",
    "source/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "source/.vitepress/.temp"
  ]
}
